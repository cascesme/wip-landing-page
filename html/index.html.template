<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$WIP_TITLE</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      background: #050505;
      font-family: 'Google Sans', Inter, system-ui, sans-serif;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.15;
      z-index: -1;
      pointer-events: none;
      will-change: transform;
    }

    .blob-1 {
      width: 40vw;
      height: 40vw;
      background: #4285F4;
      top: -10vw;
      left: -10vw;
      animation: drift-1 3s ease-in-out infinite alternate;
    }

    .blob-2 {
      width: 35vw;
      height: 35vw;
      background: #EA4335;
      bottom: -5vw;
      right: -10vw;
      animation: drift-2 3.5s ease-in-out infinite alternate;
    }

    .blob-3 {
      width: 30vw;
      height: 30vw;
      background: #FBBC04;
      top: 20vh;
      right: 20vw;
      animation: drift-3 4.5s ease-in-out infinite alternate;
    }

    .blob-4 {
      width: 25vw;
      height: 25vw;
      background: #34A853;
      bottom: 10vh;
      left: 20vw;
      animation: drift-4 2.5s ease-in-out infinite alternate;
    }

    @keyframes drift-1 {
      from { transform: translate(-60px, 80px)  scale(1);    opacity: 0.12; }
      to   { transform: translate(80px, -60px)  scale(1.2);  opacity: 0.22; }
    }

    @keyframes drift-2 {
      from { transform: translate(70px, 60px)   scale(1);    opacity: 0.12; }
      to   { transform: translate(-80px, -70px) scale(1.25); opacity: 0.24; }
    }

    @keyframes drift-3 {
      from { transform: translate(50px, -70px)  scale(1);    opacity: 0.10; }
      to   { transform: translate(-70px, 80px)  scale(1.35); opacity: 0.20; }
    }

    @keyframes drift-4 {
      from { transform: translate(-50px, -70px) scale(1);    opacity: 0.13; }
      to   { transform: translate(70px, 50px)   scale(1.15); opacity: 0.22; }
    }

    .container {
      text-align: center;
      z-index: 1;
      padding: 2rem;
      max-width: 600px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .illustration {
      width: 200px;
      height: 200px;
      animation: float 3s ease-in-out infinite;
    }

    .pulse-ring {
      animation: pulse-ring 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
      transform-origin: center;
    }

    @keyframes float {
      0%   { transform: translateY(0px); }
      50%  { transform: translateY(-15px); }
      100% { transform: translateY(0px); }
    }

    @keyframes pulse-ring {
      0%   { transform: scale(0.8); opacity: 0.8; stroke-width: 8px; }
      100% { transform: scale(1.4); opacity: 0; stroke-width: 1px; }
    }

    h1 {
      font-size: clamp(2rem, 5vw, 4.5rem);
      font-weight: 600;
      color: #e5e2e1;
      letter-spacing: -0.04em;
      line-height: 1.1;
    }

    .accent-bar {
      width: 96px;
      height: 3px;
      border-radius: 9999px;
      background: linear-gradient(90deg, #4285F4, #EA4335, #FBBC04, #34A853, #4285F4);
      background-size: 200% 100%;
      animation: gradient-slide 4s linear infinite;
    }

    @keyframes gradient-slide {
      0%   { background-position: 0% 50%; }
      100% { background-position: 200% 50%; }
    }

    p {
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: rgba(255,255,255,0.6);
      line-height: 1.6;
      max-width: 42rem;
    }
  </style>
</head>
<body>
  <!-- Gradient blobs -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="blob blob-4"></div>

  <div class="container">
    <!-- SVG Illustration -->
    <svg class="illustration" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="rocketBody" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#5a9cf8"/>
          <stop offset="100%" stop-color="#1a73e8"/>
        </linearGradient>
        <linearGradient id="flameOuter" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#FBBC04"/>
          <stop offset="100%" stop-color="#EA4335" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="flameInner" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#ffffff"/>
          <stop offset="100%" stop-color="#FBBC04" stop-opacity="0"/>
        </linearGradient>
      </defs>

      <!-- Stars -->
      <circle cx="40"  cy="45"  r="2"   fill="white" opacity="0.5"/>
      <circle cx="160" cy="35"  r="1.5" fill="white" opacity="0.4"/>
      <circle cx="158" cy="90"  r="2"   fill="white" opacity="0.3"/>
      <circle cx="35"  cy="105" r="1.5" fill="white" opacity="0.4"/>
      <circle cx="170" cy="128" r="1"   fill="white" opacity="0.3"/>
      <circle cx="28"  cy="148" r="2"   fill="white" opacity="0.3"/>

      <!-- Flame -->
      <path d="M 87,142 Q 89,170 100,182 Q 111,170 113,142 Z" fill="url(#flameOuter)"/>
      <path d="M 93,142 Q 95,160 100,168 Q 105,160 107,142 Z" fill="url(#flameInner)"/>

      <!-- Left fin -->
      <path d="M 87,108 L 58,142 L 87,142 Z" fill="#EA4335"/>
      <path d="M 87,108 L 66,133 L 87,133 Z" fill="#c5221f" opacity="0.35"/>

      <!-- Right fin -->
      <path d="M 113,108 L 142,142 L 113,142 Z" fill="#EA4335"/>
      <path d="M 113,108 L 134,133 L 113,133 Z" fill="#c5221f" opacity="0.35"/>

      <!-- Rocket body -->
      <path d="M 87,138 L 87,72 Q 87,20 100,13 Q 113,20 113,72 L 113,138 Z" fill="url(#rocketBody)"/>

      <!-- Body highlight -->
      <path d="M 87,138 L 87,72 Q 87,20 100,13 L 100,138 Z" fill="white" opacity="0.07"/>

      <!-- Thruster base -->
      <rect x="87" y="132" width="26" height="10" rx="3" fill="#1557b0"/>

      <!-- Green side stripes -->
      <rect x="87" y="95" width="4" height="22" rx="2" fill="#34A853" opacity="0.8"/>
      <rect x="109" y="95" width="4" height="22" rx="2" fill="#34A853" opacity="0.8"/>

      <!-- Window ring -->
      <circle cx="100" cy="70" r="17" fill="white" opacity="0.12"/>
      <!-- Window -->
      <circle cx="100" cy="70" r="13" fill="white" opacity="0.92"/>
      <circle cx="100" cy="70" r="9"  fill="#4285F4" opacity="0.45"/>
      <!-- Window highlight -->
      <circle cx="95"  cy="65" r="3.5" fill="white" opacity="0.75"/>

      <!-- Pulse ring -->
      <circle class="pulse-ring" cx="100" cy="70" r="18" fill="none" stroke="#4285F4" stroke-width="2"/>
    </svg>

    <h1>$WIP_TITLE</h1>
    <div class="accent-bar"></div>
    <p>$WIP_SUBTITLE</p>
  </div>
</body>
</html>
